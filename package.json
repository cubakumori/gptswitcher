{
  "name": "gpt-switcher-mac",
  "productName": "GPT Switcher",
  "version": "1.0.0",
  "description": "Desktop manager for ChatGPT accounts",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dist": "vite build && electron-builder"
  },
  "dependencies": {
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^39.2.4",
    "electron-builder": "^24.13.0",
    "typescript": "^5.4.0",
    "vite": "^7.2.6"
  },
  "build": {
    "appId": "com.gptswitcher.app",
    "mac": {
      "category": "public.app-category.productivity",
      "target": {
        "target": "dmg",
        "arch": ["arm64", "x64"]
      },
      "icon": "icon.icns"
    },
    "compression": "maximum",
    "asar": true,
    "files": [
      "dist/**/*",
      "main.js",
      "package.json",
      "!**/node_modules/**/*",
      "!**/*.ts",
      "!**/*.tsx",
      "!src/**/*",
      "!vite.config.ts",
      "!tsconfig.*"
    ],
    "directories": {
      "output": "dist-electron"
    }
  }
}
